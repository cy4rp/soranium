# 自前BSV TestnetノードのARCエンドポイント
ARC_URL=http://localhost:9090
# ARCに認証が必要な場合のみ
ARC_API_KEY=
# RECEIVED | STORED | ANNOUNCED_TO_NETWORK | SEEN_ON_NETWORK
ARC_WAIT_FOR=SEEN_ON_NETWORK
# マークルプルーフ/ステータスのコールバック先(任意)
ARC_CALLBACK_URL=

PORT=3000
DB_PATH=./orderbook.sqlite
# sat/kB
FEE_PER_KB=50
NETWORK=testnet
